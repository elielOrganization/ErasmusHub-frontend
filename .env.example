# URL de la API para el navegador (client-side)
# En produccion: /api (proxied por Next.js rewrites)
# En desarrollo: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# URL publica del backend (para rewrites de Next.js)
# En produccion: https://erasmushub-api.vercel.app
# En desarrollo: http://127.0.0.1:8000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# URL del backend para server-side (SSR) - conexion directa
# En produccion: https://erasmushub-api.vercel.app
# En desarrollo: http://127.0.0.1:8000
SERVER_API_URL=http://127.0.0.1:8000
